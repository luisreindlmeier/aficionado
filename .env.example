# Backend env for /api (Vercel Functions). Copy to .env.local for `vercel dev`.

# Vercel AI Gateway key. Without it, /api/evaluate falls back to a heuristic
# Proof score instead of an AI verdict. On Vercel this is injected automatically.
AI_GATEWAY_API_KEY=

# Mastra Platform observability (agent traces + metrics in the Mastra dashboard).
# Get both from the Mastra dashboard. Only used once the app runs on Mastra.
MASTRA_PLATFORM_ACCESS_TOKEN=
MASTRA_PROJECT_ID=

# OpenAI model key. Mastra runs all agents through OpenAI (provider string
# "openai/..." looks for OPENAI_API_KEY). Absent = deterministic heuristic fallback.
OPENAI_API_KEY=

# Optional: raises the GitHub API rate limit (60/h -> 5000/h).
GITHUB_TOKEN=

# Optional: enables the Product Hunt connector (developer token).
PRODUCT_HUNT_TOKEN=

# Optional: raises the Stack Exchange quota. The connector works keyless
# (Semantic Scholar and Wayback are keyless too, no env needed).
STACK_EXCHANGE_KEY=

# Optional, for later: paid X (Twitter) API for the Gravity connector.
X_API_KEY=

# Optional, for later: OpenRegister key for German company filings.
OPENREGISTER_KEY=

# Optional, for later: Supabase, so the Loop A sourcing cron (/api/sourcing)
# can persist discovered candidates. Absent = the pass runs read-only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
